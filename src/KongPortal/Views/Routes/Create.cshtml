@{ ViewData["Title"] = "Add Route"; var serviceId = ViewBag.ServiceId as string; }
<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header fw-semibold">New Route</div>
      <div class="card-body">
        <form method="post" action="/routes/create?serviceId=@serviceId">
          @Html.AntiForgeryToken()
          <div class="mb-3">
            <label class="form-label">Name</label>
            <input name="Name" class="form-control" placeholder="my-route" />
          </div>
          <div class="mb-3">
            <label class="form-label">Paths (comma separated)</label>
            <input name="paths" class="form-control" placeholder="/api/v1/resource" />
          </div>
          <div class="mb-4">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="StripPath" value="true" checked />
              <label class="form-check-label">Strip Path</label>
            </div>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Create</button>
            <a href="/services/@serviceId" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
