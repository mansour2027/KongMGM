@model KongPortal.Models.ViewModels.DashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }

<div class="row g-3 mb-4">
    <div class="col-md-2">
        <div class="card stat-card bg-primary text-white">
            <div class="card-body">
                <div class="stat-number">@Model.TotalConsumers</div>
                <div>Consumers</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card stat-card bg-success text-white">
            <div class="card-body">
                <div class="stat-number">@Model.TotalServices</div>
                <div>Services</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card stat-card bg-info text-white">
            <div class="card-body">
                <div class="stat-number">@Model.TotalRoutes</div>
                <div>Routes</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card stat-card bg-secondary text-white">
            <div class="card-body">
                <div class="stat-number">@Model.TotalPlugins</div>
                <div>Plugins</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card stat-card bg-warning text-dark">
            <div class="card-body">
                <div class="stat-number">@Model.OverdueRotations</div>
                <div>Overdue</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card stat-card bg-danger text-white">
            <div class="card-body">
                <div class="stat-number">@Model.PendingDeletions</div>
                <div>Pending Delete</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header fw-semibold">Recent Activity</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Action</th><th>Resource</th>
                            <th>By</th><th>When</th><th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var log in Model.RecentActivity)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@log.Action</span></td>
                            <td>@log.Resource</td>
                            <td>@log.PerformedBy</td>
                            <td>@log.At.ToString("dd MMM HH:mm")</td>
                            <td>@(log.Success ? "✅" : "❌")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header fw-semibold">Quick Actions</div>
            <div class="card-body d-grid gap-2">
                <a href="/consumers" class="btn btn-outline-primary">
                    <i class="bi bi-people me-2"></i>Manage Consumers
                </a>
                <a href="/rotation" class="btn btn-outline-warning">
                    <i class="bi bi-arrow-repeat me-2"></i>Rotation Center
                </a>
                <a href="/services" class="btn btn-outline-success">
                    <i class="bi bi-hdd-network me-2"></i>Manage Services
                </a>
                <a href="/audit" class="btn btn-outline-secondary">
                    <i class="bi bi-journal-text me-2"></i>View Audit Log
                </a>
            </div>
        </div>
    </div>
</div>
