@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login — Kong Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background: #1a1f36; display:flex; align-items:center; justify-content:center; min-height:100vh; }
        .login-card { width: 380px; border-radius: 16px; }
    </style>
</head>
<body>
    <div class="card login-card shadow-lg">
        <div class="card-body p-4">
            <h4 class="fw-bold text-center mb-1">🔐 Kong Portal</h4>
            <p class="text-muted text-center small mb-4">DevOps Team Access Only</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2 small">Invalid credentials or account locked.</div>
            }

            <form method="post" action="/account/login">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                <div class="mb-3">
                    <label class="form-label small fw-semibold">Username</label>
                    <input name="username" class="form-control" autofocus required />
                </div>
                <div class="mb-4">
                    <label class="form-label small fw-semibold">Password</label>
                    <input name="password" type="password" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary w-100 fw-semibold">Sign In</button>
            </form>
        </div>
    </div>
</body>
</html>
