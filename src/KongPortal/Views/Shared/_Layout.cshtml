<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Kong Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body { display: flex; min-height: 100vh; background: #f8f9fa; }
        .sidebar {
            width: 240px; min-height: 100vh;
            background: #1a1f36; color: #fff;
            display: flex; flex-direction: column;
            position: fixed; top: 0; left: 0; bottom: 0;
        }
        .sidebar-brand {
            padding: 1.5rem 1rem;
            font-size: 1.1rem; font-weight: 700;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .sidebar-brand span { color: #7c8cf8; }
        .sidebar-nav { flex: 1; padding: 1rem 0; }
        .sidebar-section {
            padding: 0.5rem 1rem 0.25rem;
            font-size: 0.7rem; text-transform: uppercase;
            letter-spacing: 1px; color: rgba(255,255,255,0.4);
        }
        .sidebar-nav .nav-link {
            color: rgba(255,255,255,0.75);
            padding: 0.5rem 1rem;
            border-radius: 0;
            display: flex; align-items: center; gap: 0.6rem;
        }
        .sidebar-nav .nav-link:hover,
        .sidebar-nav .nav-link.active {
            color: #fff;
            background: rgba(124,140,248,0.2);
            border-left: 3px solid #7c8cf8;
        }
        .sidebar-nav .nav-link i { width: 1.2rem; }
        .main-content { margin-left: 240px; flex: 1; padding: 0; width: calc(100% - 240px); }
        .topbar {
            background: #fff; border-bottom: 1px solid #e9ecef;
            padding: 0.75rem 1.5rem;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 100;
        }
        .page-content { padding: 1.5rem; }
        .badge-key-auth   { background: #0d6efd; }
        .badge-jwt        { background: #6f42c1; }
        .badge-basic-auth { background: #198754; }
        .badge-hmac-auth  { background: #fd7e14; }
        .badge-oauth2     { background: #dc3545; }
        .overdue { background-color: #fff5f5 !important; }
        .stat-card { border: none; border-radius: 12px; }
        .stat-card .card-body { padding: 1.25rem; }
        .stat-number { font-size: 2rem; font-weight: 700; }
    </style>
</head>
<body>

<!-- Sidebar -->
<div class="sidebar">
    <div class="sidebar-brand">
        <i class="bi bi-shield-lock-fill me-2"></i>Kong <span>Portal</span>
    </div>
    <nav class="sidebar-nav">
        <div class="sidebar-section">Overview</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
           href="/">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <div class="sidebar-section mt-2">Gateway</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Consumers" ? "active" : "")"
           href="/consumers">
            <i class="bi bi-people"></i> Consumers
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Services" ? "active" : "")"
           href="/services">
            <i class="bi bi-hdd-network"></i> Services
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Routes" ? "active" : "")"
           href="/routes">
            <i class="bi bi-signpost-split"></i> Routes
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Plugins" ? "active" : "")"
           href="/plugins">
            <i class="bi bi-puzzle"></i> Plugins
        </a>

        <div class="sidebar-section mt-2">Operations</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Rotation" ? "active" : "")"
           href="/rotation">
            <i class="bi bi-arrow-repeat"></i> Rotation Center
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Audit" ? "active" : "")"
           href="/audit">
            <i class="bi bi-journal-text"></i> Audit Log
        </a>
    </nav>
    <div class="p-3 border-top" style="border-color: rgba(255,255,255,0.1) !important; font-size:0.8rem; color:rgba(255,255,255,0.4)">
        Logged in as <strong class="text-white">@User.Identity?.Name</strong>
        <form action="/account/logout" method="post" class="d-inline ms-2">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-link btn-sm p-0 text-danger">Logout</button>
        </form>
    </div>
</div>

<!-- Main -->
<div class="main-content">
    <div class="topbar">
        <h6 class="mb-0 fw-semibold">@ViewData["Title"]</h6>
        <div class="d-flex gap-2">
            @if (TempData["Success"] != null)
            {
                <span class="badge bg-success p-2">✅ @TempData["Success"]</span>
            }
            @if (TempData["Error"] != null)
            {
                <span class="badge bg-danger p-2">❌ @TempData["Error"]</span>
            }
        </div>
    </div>
    <div class="page-content">
        @RenderBody()
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
