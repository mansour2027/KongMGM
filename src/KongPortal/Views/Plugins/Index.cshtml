@model List<KongPortal.Models.Kong.KongPlugin>
@{ ViewData["Title"] = "Plugins"; }

<div class="d-flex justify-content-end mb-3">
    <a href="/plugins/create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Add Plugin
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Scope</th><th>Status</th><th>Actions</th></tr>
            </thead>
            <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td class="fw-semibold">@p.Name</td>
                    <td class="small text-muted">
                        @(p.ServiceId != null ? "Service" : p.ConsumerId != null ? "Consumer" : "Global")
                    </td>
                    <td>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox"
                                   @(p.Enabled ? "checked" : "")
                                   onchange="togglePlugin('@p.Id', this.checked)" />
                        </div>
                    </td>
                    <td>
                        <form method="post" action="/plugins/@p.Id/delete" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm"
                                    onclick="return confirm('Delete plugin @p.Name?')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
async function togglePlugin(id, enabled) {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    await fetch(`/plugins/${id}/toggle`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
        body: JSON.stringify({ pluginId: id, enabled })
    });
}
</script>
@Html.AntiForgeryToken()
}
