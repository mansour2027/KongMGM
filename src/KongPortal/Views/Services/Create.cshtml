@{ ViewData["Title"] = "Add Service"; }
<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header fw-semibold">New Service</div>
      <div class="card-body">
        <form method="post" action="/services/create">
          @Html.AntiForgeryToken()
          <div class="mb-3">
            <label class="form-label">Name <span class="text-danger">*</span></label>
            <input name="Name" class="form-control" required placeholder="property-api" />
          </div>
          <div class="mb-3">
            <label class="form-label">Host <span class="text-danger">*</span></label>
            <input name="Host" class="form-control" required placeholder="property-service.internal" />
          </div>
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="form-label">Port</label>
              <input name="Port" type="number" class="form-control" value="80" />
            </div>
            <div class="col-md-6">
              <label class="form-label">Protocol</label>
              <select name="Protocol" class="form-select">
                <option value="http">http</option>
                <option value="https">https</option>
                <option value="grpc">grpc</option>
              </select>
            </div>
          </div>
          <div class="mb-4">
            <label class="form-label">Path</label>
            <input name="Path" class="form-control" placeholder="/api/v1" />
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Create Service</button>
            <a href="/services" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
