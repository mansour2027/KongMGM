@model KongPortal.Models.ViewModels.RotationStatusViewModel
@{ ViewData["Title"] = "Rotation Center"; }

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card text-center border-0 bg-secondary text-white">
            <div class="card-body py-2">
                <div class="fs-3 fw-bold">@Model.Total</div><div class="small">Total Records</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-0 bg-warning text-dark">
            <div class="card-body py-2">
                <div class="fs-3 fw-bold">@Model.Pending</div><div class="small">Awaiting Confirmation</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-0 bg-success text-white">
            <div class="card-body py-2">
                <div class="fs-3 fw-bold">@Model.Confirmed</div><div class="small">Confirmed</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-0 bg-primary text-white">
            <div class="card-body py-2">
                <div class="fs-3 fw-bold">@Model.Deleted</div><div class="small">Old Keys Deleted</div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Rotation Records</span>
        <button class="btn btn-danger btn-sm" onclick="deleteSelected()">
            <i class="bi bi-trash me-1"></i>Delete Old Keys (Confirmed Only)
        </button>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>☑</th>
                    <th>Consumer</th>
                    <th>Service</th>
                    <th>Auth Type</th>
                    <th>Contact</th>
                    <th>Rotated</th>
                    <th>By</th>
                    <th>Confirmed</th>
                    <th>Deleted</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var r in Model.Records)
            {
                <tr>
                    <td>
                        <input type="checkbox" class="form-check-input record-cb"
                               value="@r.Id" @(!r.Confirmed || r.OldCredentialsDeleted ? "disabled" : "") />
                    </td>
                    <td><a href="/consumers/@r.KongConsumerUsername">@r.KongConsumerUsername</a></td>
                    <td>@r.ServiceName</td>
                    <td><span class="badge bg-secondary">@r.AuthType</span></td>
                    <td class="small text-muted">@r.ContactEmail</td>
                    <td class="small">@r.RotatedAt.ToString("dd MMM HH:mm")</td>
                    <td class="small">@r.RotatedBy</td>
                    <td>
                        @if (r.Confirmed)
                        {
                            <span class="badge bg-success">✅ Yes</span>
                        }
                        else
                        {
                            <form method="post" action="/rotation/confirm/@r.Id" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-success btn-sm">Confirm</button>
                            </form>
                        }
                    </td>
                    <td>@(r.OldCredentialsDeleted ? "🗑️ Yes" : "—")</td>
                    <td>
                        @if (r.Confirmed && !r.OldCredentialsDeleted)
                        {
                            <span class="badge bg-warning text-dark">Ready to delete</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
async function deleteSelected() {
    const ids = [...document.querySelectorAll('.record-cb:checked:not(:disabled)')]
                .map(cb => parseInt(cb.value));
    if (!ids.length) return alert('Select confirmed records to delete old keys');
    if (!confirm(`Delete old credentials for ${ids.length} record(s)?`)) return;

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    const resp = await fetch('/rotation/delete-old', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
        body: JSON.stringify(ids)
    });
    const result = await resp.json();
    alert(`🗑️ ${result.deleted} deleted, ⚠️ ${result.skipped} skipped`);
    window.location.reload();
}
</script>
@Html.AntiForgeryToken()
}
