@model List<KongPortal.Models.Domain.RotationRecord>
@{ ViewData["Title"] = "Rotation History"; }

<div class="card mb-3">
  <div class="card-body py-2">
    <form method="get" class="d-flex gap-2 align-items-center">
      <input name="consumer" class="form-control form-control-sm" placeholder="Consumer"
             style="width:200px" value="@Context.Request.Query["consumer"]" />
      <input name="from" type="date" class="form-control form-control-sm" style="width:160px"
             value="@Context.Request.Query["from"]" />
      <input name="to" type="date" class="form-control form-control-sm" style="width:160px"
             value="@Context.Request.Query["to"]" />
      <button type="submit" class="btn btn-outline-secondary btn-sm">Filter</button>
      <a href="/rotation/history" class="btn btn-outline-danger btn-sm">Clear</a>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-body p-0">
    <table class="table table-hover table-sm align-middle mb-0">
      <thead class="table-light">
        <tr><th>Consumer</th><th>Auth Type</th><th>Service</th><th>Rotated</th>
            <th>By</th><th>Confirmed</th><th>Deleted</th></tr>
      </thead>
      <tbody>
      @foreach (var r in Model)
      {
        <tr>
          <td><a href="/consumers/@r.KongConsumerUsername">@r.KongConsumerUsername</a></td>
          <td><span class="badge bg-secondary">@r.AuthType</span></td>
          <td class="small text-muted">@r.ServiceName</td>
          <td class="small">@r.RotatedAt.ToString("dd MMM yyyy HH:mm")</td>
          <td class="small">@r.RotatedBy</td>
          <td>@(r.Confirmed ? "✅" : "⏳")</td>
          <td>@(r.OldCredentialsDeleted ? "🗑️" : "—")</td>
        </tr>
      }
      </tbody>
    </table>
  </div>
</div>
